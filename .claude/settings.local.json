{
  "permissions": {
    "allow": [
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_search",
      "Bash(grep -r \"UpdateInGroup\\\\|UpdateAfter\" /c/Users/VRINO/desarrollo/Conquest_prototype/Assets/Scripts/Squads/Systems/*.cs | grep -E \"\\(SquadSpawning|GridFormationUpdate|UnitFollowFormation|UnitFormationState|Formation\\\\.System\\)\" | head -20)",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "Bash(find . -name *.controller -o -name *SampleAnimationController*)",
      "Bash(grep -E '\\\\.cs$')",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "Bash(xargs grep:*)",
      "Bash(grep -r \"class.*Detection\\\\|class.*Targeting\" /c/Users/VRINO/desarrollo/Conquest_prototype/Assets/Scripts --include=*.cs -n)",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[HOOK] REUSE-CHECK: Antes de crear este archivo, debes haber ejecutado /reuse-check. Si no lo hiciste, detente y hazlo ahora.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[HOOK] NO-MAGIC-PARAMS: Revisa si el codigo que acabas de escribir contiene literales numericos o strings de configuracion. Si los hay, ejecuta /no-magic-params.'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context-mode@context-mode": true
  }
}
